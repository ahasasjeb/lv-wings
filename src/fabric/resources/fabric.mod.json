{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "contact": {
    "homepage": "${mod_display_url}",
    "issues": "${mod_issue_url}"
  },
  "license": "${mod_license}",
  "icon": "${mod_logo}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "cc.lvjia.wings.WingsMod"
    ],
    "client": [
      "cc.lvjia.wings.client.WingsClient"
    ]
  },
  "mixins": [
    "wings.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-api": "*",
    "java": ">=25"
  }
}
